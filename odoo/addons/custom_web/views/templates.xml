<odoo>
  <data>
    <template id="portfolio_page" name="Custom Web Page">
      <t t-call="website.layout">
        <div class="portfolio-page-marker d-none" aria-hidden="true"></div>
        <style>
          html:has(.portfolio-page-marker) footer#bottom,
          html:has(.portfolio-page-marker) .o_footer,
          html:has(.portfolio-page-marker) .o_footer_copyright,
          html:has(.portfolio-page-marker) #footer {
            display: none !important;
          }
        </style>
        <script type="text/javascript">
          document.addEventListener('DOMContentLoaded', function () {
            if (!document.querySelector('.portfolio-page-marker')) {
              return;
            }
            ['footer#bottom', '.o_footer_copyright'].forEach(function (selector) {
              document.querySelectorAll(selector).forEach(function (node) {
                node.remove();
              });
            });
          });
        </script>
        <div class="portfolio-page">
          <header id="header" class="header dark-background d-flex flex-column">
            <i class="header-toggle d-xl-none bi bi-list"></i>

            <div class="header-minimal">
              <div class="profile-img">
                <img
                  t-att-src="portfolio.get_profile_image_url() if portfolio and portfolio.profile_image else '/custom_web/static/src/img/my-profile-img.webp'"
                  alt="Gabriel Paredes" class="img-fluid rounded-circle" />
              </div>

              <a href="#hero" class="logo d-flex align-items-center justify-content-center">
                <h1 class="sitename">
                  <t t-esc="portfolio.name if portfolio else 'Portfolio'" />
                </h1>
              </a>
              <p class="header-role">
                <t t-esc="portfolio.focus_text if portfolio and portfolio.focus_text else 'Odoo, full-stack apps, automation'" />
              </p>
            </div>

            <div class="social-links text-center">
              <t t-if="portfolio and portfolio.social_link_ids">
                <t t-foreach="portfolio.social_link_ids" t-as="social">
                  <a t-att-href="social.url" target="_blank" rel="noopener noreferrer"
                    t-att-aria-label="social.name">
                    <i t-att-class="social.icon_class"></i>
                  </a>
                </t>
              </t>
            </div>

            <nav id="navmenu" class="navmenu">
              <ul>
                <li><a href="#hero" class="active"><i class="bi bi-house navicon"></i> Home</a></li>
                <li><a href="#about"><i class="bi bi-person navicon"></i> About</a></li>
                <li><a href="#skills"><i class="bi bi-hdd-stack navicon"></i> Skills</a></li>
                <li><a href="#resume"><i class="bi bi-file-earmark-text navicon"></i> Resume</a></li>
                <li><a href="#portfolio"><i class="bi bi-grid navicon"></i> Portfolio</a></li>
                <li><a href="#contact"><i class="bi bi-envelope navicon"></i> Contact</a></li>
              </ul>
            </nav>
          </header>

          <main class="main">
            <section id="hero" class="hero section dark-background">
              <img
                t-att-src="portfolio.get_hero_background_url() if portfolio and portfolio.hero_background_image else '/custom_web/static/src/img/background.webp'"
                alt="Portfolio background" data-aos="fade-in" class="hero-background" />

              <div class="container hero-shell" data-aos="fade-up" data-aos-delay="100">
                <div class="hero-minimal">
                  <p class="hero-kicker">
                    <t t-esc="portfolio.focus_text if portfolio and portfolio.focus_text else 'Odoo, full-stack apps, automation'" />
                  </p>
                  <h2>
                    <t t-esc="portfolio.hero_title if portfolio and portfolio.hero_title else 'Engineering digital products that feel solid, useful, and ready for the real world.'" />
                  </h2>
                  <p class="hero-copy">
                    <t t-esc="portfolio.hero_intro if portfolio and portfolio.hero_intro else ''" />
                  </p>
                  <div class="hero-actions">
                    <a href="#portfolio" class="btn btn-primary hero-btn">View Projects</a>
                    <a href="#contact" class="btn btn-outline-light hero-btn secondary">Contact</a>
                  </div>
                </div>
              </div>
            </section>

            <section id="about" class="about section">
              <div class="container section-title" data-aos="fade-up">
                <h2>About</h2>
                <p>
                  <t t-esc="portfolio.about_text if portfolio and portfolio.about_text else ''" />
                </p>
              </div>

              <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="row gy-5 align-items-center">
                  <div class="col-lg-5">
                    <div class="about-portrait">
                      <img
                        t-att-src="portfolio.get_profile_image_url() if portfolio and portfolio.profile_image else '/custom_web/static/src/img/my-profile-img.webp'"
                        class="img-fluid" alt="Portrait" />
                    </div>
                  </div>
                  <div class="col-lg-7">
                    <div class="about-panel">
                      <h3>
                        <t t-esc="portfolio.about_title if portfolio and portfolio.about_title else 'Full-stack developer with a systems view'" />
                      </h3>
                      <p>
                        <t t-esc="portfolio.about_text if portfolio and portfolio.about_text else ''" />
                      </p>
                      <div class="row g-3 info-grid">
                        <div class="col-md-6" t-if="portfolio and portfolio.website_url">
                          <div class="info-chip">
                            <span>Website</span>
                            <strong>
                              <a t-att-href="portfolio.website_url" target="_blank" rel="noopener noreferrer">
                                <t t-esc="portfolio.website_url" />
                              </a>
                            </strong>
                          </div>
                        </div>
                        <div class="col-md-6" t-if="portfolio and portfolio.email">
                          <div class="info-chip">
                            <span>Email</span>
                            <strong>
                              <a t-att-href="'mailto:%s' % portfolio.email">
                                <t t-esc="portfolio.email" />
                              </a>
                            </strong>
                          </div>
                        </div>
                        <div class="col-md-6" t-if="portfolio and portfolio.phone">
                          <div class="info-chip">
                            <span>Phone</span>
                            <strong>
                              <a t-att-href="'tel:%s' % portfolio.phone.replace(' ', '')">
                                <t t-esc="portfolio.phone" />
                              </a>
                            </strong>
                          </div>
                        </div>
                        <div class="col-md-6" t-if="portfolio and portfolio.availability_text">
                          <div class="info-chip">
                            <span>Availability</span>
                            <strong>
                              <t t-esc="portfolio.availability_text" />
                            </strong>
                          </div>
                        </div>
                      </div>
                      <div class="impact-grid">
                        <div class="impact-card">
                          <strong><t t-esc="portfolio.clients_count if portfolio else 0" />+</strong>
                          <span>Clients supported</span>
                        </div>
                        <div class="impact-card">
                          <strong><t t-esc="portfolio.projects_count if portfolio else 0" />+</strong>
                          <span>Projects delivered</span>
                        </div>
                        <div class="impact-card">
                          <strong><t t-esc="portfolio.years_count if portfolio else 0" />+</strong>
                          <span>Years building and volunteering</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section id="skills" class="skills section light-background">
              <div class="container section-title" data-aos="fade-up">
                <h2>Skills</h2>
                <p>
                  <t t-esc="portfolio.skills_intro if portfolio and portfolio.skills_intro else ''" />
                </p>
              </div>

              <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="capability-grid">
                  <t t-foreach="portfolio.skill_category_ids if portfolio else []" t-as="category">
                    <div class="capability-panel">
                      <h3><t t-esc="category.name" /></h3>
                      <div class="skill-pills">
                        <t t-foreach="category.skill_ids" t-as="skill">
                          <span><t t-esc="skill.name" /></span>
                        </t>
                      </div>
                    </div>
                  </t>
                </div>
              </div>
            </section>

            <section id="resume" class="resume section">
              <div class="container section-title" data-aos="fade-up">
                <h2>Resume</h2>
                <p>
                  <t t-esc="portfolio.resume_intro if portfolio and portfolio.resume_intro else ''" />
                </p>
              </div>

              <div class="container">
                <div class="row gy-4">
                  <div class="col-lg-7" data-aos="fade-up" data-aos-delay="100">
                    <div class="timeline-panel">
                      <h3 class="resume-title">Experience</h3>
                      <t t-foreach="portfolio.experience_ids if portfolio else []" t-as="experience">
                        <div class="resume-item">
                          <h4><t t-esc="experience.title" /></h4>
                          <h5><t t-esc="experience.period" /></h5>
                          <p><em><t t-esc="experience.company" /></em></p>
                          <ul>
                            <t t-foreach="experience.highlights.splitlines() if experience.highlights else []" t-as="line">
                              <li t-if="line.strip()"><t t-esc="line.strip()" /></li>
                            </t>
                          </ul>
                        </div>
                      </t>
                    </div>
                  </div>
                  <div class="col-lg-5" data-aos="fade-up" data-aos-delay="200">
                    <div class="resume-side-grid">
                      <div class="capability-panel">
                        <h3>Education</h3>
                        <t t-foreach="portfolio.education_ids if portfolio else []" t-as="education">
                          <div class="education-item">
                            <strong><t t-esc="education.title" /></strong>
                            <span><t t-esc="education.institution" /></span>
                            <small><t t-esc="education.year" /></small>
                          </div>
                        </t>
                      </div>
                      <div class="capability-panel">
                        <h3>Languages</h3>
                        <t t-foreach="portfolio.language_ids if portfolio else []" t-as="language">
                          <div class="language-row">
                            <span><t t-esc="language.name" /></span>
                            <strong><t t-esc="language.level" /></strong>
                          </div>
                        </t>
                      </div>
                      <div class="capability-panel" t-if="portfolio and portfolio.community_text">
                        <h3>Community</h3>
                        <p><t t-esc="portfolio.community_text" /></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section id="portfolio" class="portfolio section light-background">
              <div class="container section-title" data-aos="fade-up">
                <h2>Selected Work</h2>
                <p>
                  <t t-esc="portfolio.portfolio_intro if portfolio and portfolio.portfolio_intro else ''" />
                </p>
              </div>

              <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="project-grid">
                  <t t-foreach="portfolio.project_ids if portfolio else []" t-as="project">
                    <article class="project-card">
                      <div class="project-media">
                        <img
                          t-att-src="project.get_image_url() if project.image else '/custom_web/static/src/img/portfolio/app-1.webp'"
                          t-att-alt="project.name" class="img-fluid" />
                      </div>
                      <div class="project-content">
                        <span class="project-type"><t t-esc="project.project_type" /></span>
                        <h3><t t-esc="project.name" /></h3>
                        <p><t t-esc="project.summary" /></p>
                        <a t-if="project.image" t-att-href="project.get_image_url()"
                          class="project-link glightbox" data-gallery="portfolio-gallery"
                          t-att-title="project.name">Preview Project</a>
                        <a t-elif="project.project_url" t-att-href="project.project_url"
                          class="project-link" target="_blank" rel="noopener noreferrer">Open Project</a>
                      </div>
                    </article>
                  </t>
                </div>
              </div>
            </section>

            <section id="contact" class="contact section">
              <div class="container section-title" data-aos="fade-up">
                <h2>Contact</h2>
                <p>
                  <t t-esc="portfolio.contact_intro if portfolio and portfolio.contact_intro else ''" />
                </p>
              </div>

              <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="contact-shell">
                  <t t-foreach="portfolio.contact_item_ids if portfolio else []" t-as="item">
                    <div class="contact-card">
                      <i t-att-class="item.icon_class"></i>
                      <h3><t t-esc="item.label" /></h3>
                      <a t-att-href="item.link or '#'" t-att-target="'_blank' if item.link and item.link.startswith('http') else None"
                        t-att-rel="'noopener noreferrer' if item.link and item.link.startswith('http') else None">
                        <t t-esc="item.value" />
                      </a>
                    </div>
                  </t>
                </div>
              </div>
            </section>
          </main>

          <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
            <i class="bi bi-arrow-up-short"></i>
          </a>

          <div id="preloader"></div>
        </div>
      </t>
    </template>
  </data>
</odoo>
