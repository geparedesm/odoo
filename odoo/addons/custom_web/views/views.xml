<odoo>
  <data>
    <record id="view_portfolio_profile_tree" model="ir.ui.view">
      <field name="name">portfolio.profile.tree</field>
      <field name="model">portfolio.profile</field>
      <field name="arch" type="xml">
        <tree>
          <field name="sequence" widget="handle" />
          <field name="name" />
          <field name="website_published" />
        </tree>
      </field>
    </record>

    <record id="view_portfolio_profile_form" model="ir.ui.view">
      <field name="name">portfolio.profile.form</field>
      <field name="model">portfolio.profile</field>
      <field name="arch" type="xml">
        <form string="Portfolio Content">
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Portfolio name" />
              </h1>
            </div>
            <group>
              <group>
                <field name="sequence" />
                <field name="website_published" />
              </group>
              <group>
                <field name="website_url" />
                <field name="availability_text" />
              </group>
            </group>

            <notebook>
              <page string="Hero">
                <group>
                  <group>
                    <field name="hero_badge" />
                    <field name="hero_title" />
                    <field name="typed_items" />
                  </group>
                  <group>
                    <field name="profile_image" widget="image" class="oe_avatar" />
                    <field name="hero_background_image" widget="image" />
                  </group>
                </group>
                <group string="Summary Card">
                  <group>
                    <field name="focus_text" />
                    <field name="based_in_text" />
                    <field name="working_style_text" />
                  </group>
                </group>
              </page>

              <page string="About">
                <group>
                  <field name="about_title" />
                  <field name="about_text" nolabel="1" placeholder="Tell visitors how you work and what makes your background useful." />
                </group>
                <group string="Quick Facts">
                  <group>
                    <field name="email" />
                    <field name="phone" />
                  </group>
                  <group>
                    <field name="clients_count" />
                    <field name="projects_count" />
                    <field name="years_count" />
                  </group>
                </group>
              </page>

              <page string="Social Links">
                <field name="social_link_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                    <field name="url" />
                    <field name="icon_class" />
                  </tree>
                </field>
              </page>

              <page string="Skills">
                <field name="skills_intro" nolabel="1" placeholder="Optional intro shown above the skills section." />
                <field name="skill_category_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                  </tree>
                  <form string="Skill Category">
                    <sheet>
                      <group>
                        <field name="name" />
                        <field name="sequence" />
                      </group>
                      <field name="skill_ids" nolabel="1">
                        <tree editable="bottom">
                          <field name="sequence" widget="handle" />
                          <field name="name" />
                        </tree>
                      </field>
                    </sheet>
                  </form>
                </field>
              </page>

              <page string="Resume">
                <group>
                  <field name="resume_intro" nolabel="1" placeholder="Intro shown above the resume section." />
                  <field name="community_text" nolabel="1" placeholder="Short community or volunteering summary." />
                </group>
                <separator string="Experience" />
                <field name="experience_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="title" />
                    <field name="company" />
                    <field name="period" />
                    <field name="highlights" />
                  </tree>
                </field>
                <separator string="Education" />
                <field name="education_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="title" />
                    <field name="institution" />
                    <field name="year" />
                  </tree>
                </field>
                <separator string="Languages" />
                <field name="language_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                    <field name="level" />
                  </tree>
                </field>
              </page>

              <page string="Projects">
                <group>
                  <field name="portfolio_intro" nolabel="1" placeholder="Intro shown above the projects section." />
                </group>
                <field name="project_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="name" />
                    <field name="project_type" />
                    <field name="project_url" />
                    <field name="image" widget="image" />
                  </tree>
                </field>
              </page>

              <page string="Contact">
                <group>
                  <field name="contact_intro" nolabel="1" placeholder="Text shown above the contact cards." />
                </group>
                <field name="contact_item_ids" nolabel="1">
                  <tree editable="bottom">
                    <field name="sequence" widget="handle" />
                    <field name="label" />
                    <field name="value" />
                    <field name="link" />
                    <field name="icon_class" />
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_portfolio_profile" model="ir.actions.act_window">
      <field name="name">Portfolio Content</field>
      <field name="res_model">portfolio.profile</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_portfolio_root" name="Portfolio" sequence="40" />
    <menuitem id="menu_portfolio_content" name="Content" parent="menu_portfolio_root"
      action="action_portfolio_profile" sequence="10" />
  </data>
</odoo>
